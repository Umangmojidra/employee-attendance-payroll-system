1-- SQL Query to generate a report summarizing total net pay, total working days, and average attendance rate per department
SELECT 
    p.dep_id,
    d.dep_name,
    SUM(p.pro_rated_sal + p.per_bonus - (p.tax_amount + p.pro_fund)) AS total_net_pay,
    SUM(p.full_days + p.half_days + p.wfhs) AS total_working_days,
    AVG((p.full_days + p.half_days + p.wfhs) / 
        (p.full_days + p.half_days + p.wfhs + p.absents)) * 100 AS avg_attendance_rate
FROM payroll p
JOIN departments d ON p.dep_id = d.dep_id
GROUP BY p.dep_id, d.dep_name
ORDER BY total_net_pay DESC;

2-- Identify departments with maximum overtime 
SELECT 
    p.dep_id,
    d.dep_name,
    SUM(p.total_overtime) AS total_overtime
FROM payroll p
JOIN departments d ON p.dep_id = d.dep_id
GROUP BY p.dep_id, d.dep_name
HAVING SUM(p.total_overtime) = (
    SELECT MAX(total_overtime_sum) FROM (
        SELECT SUM(total_overtime) AS total_overtime_sum
        FROM payroll
        GROUP BY dep_id
    ) AS t
);

3-- absenteeism usingGROUP BY and HAVINGclauses.
SELECT 
    p.dep_id,
    d.dep_name,
    SUM(p.absents) AS total_absents
FROM payroll p
JOIN departments d ON p.dep_id = d.dep_id
GROUP BY p.dep_id, d.dep_name
HAVING SUM(p.absents) = (
    SELECT MAX(total_absents_sum) FROM (
        SELECT SUM(absents) AS total_absents_sum
        FROM payroll
        GROUP BY dep_id
    ) AS t
);

4-- Employees with attendancebelow 75%.
SELECT 
    e.e_id,
    e.e_name,
    p.dep_id,
    SUM(p.full_days) AS full_days,
    SUM(p.half_days) AS half_days,
    SUM(p.wfhs) AS wfh_days,
    SUM(p.absents) AS absents,
    30 * COUNT(DISTINCT p.month) AS total_working_days,
    ROUND(
        ((SUM(p.full_days) + SUM(p.half_days)*0.5 + SUM(p.wfhs)) / (30 * COUNT(DISTINCT p.month))) * 100,
        2
    ) AS attendance_percentage
FROM payroll p
JOIN employees e ON p.e_id = e.e_id
GROUP BY e.e_id, e.e_name, p.dep_id
HAVING attendance_percentage < 75
ORDER BY attendance_percentage ASC;

5-- Departments where total payroll cost exceeded  25000 .
SELECT 
    p.dep_id,
    d.dep_name,
    COUNT(DISTINCT p.e_id) AS total_employees,
    SUM(p.pro_rated_sal + p.per_bonus - (p.tax_amount + p.pro_fund)) AS total_net_pay
FROM payroll p
JOIN departments d ON p.dep_id = d.dep_id
GROUP BY p.dep_id, d.dep_name
HAVING total_net_pay > 25000
ORDER BY total_net_pay DESC;

6-- Top 5 employees with the least absenteeism or highestovertime.
SELECT 
    e.e_id,
    e.e_name,
    p.dep_id,
    SUM(p.absents) AS total_absents
FROM payroll p
JOIN employees e ON p.e_id = e.e_id
GROUP BY e.e_id, e.e_name, p.dep_id
ORDER BY total_absents ASC
LIMIT 5;

7-- Monthly reports ummarizing salary distribution and attendance trends.
SELECT 
    p.month AS month,
    COUNT(p.e_id) AS total_employees,
    SUM(p.pro_rated_sal) AS total_salary,
    AVG(p.pro_rated_sal) AS avg_salary,
    SUM(p.full_days) AS total_full_days,
    SUM(p.half_days) AS total_half_days,
    SUM(p.wfhs) AS total_wfh_days,
    SUM(p.absents) AS total_absents
FROM payroll p
GROUP BY p.month
ORDER BY month;




